# Tally Prime Configuration

# Base URL for accessing Tally Prime API
TALLY_API_URL=https://your-tally-prime-url.com

# Authentication Token
TALLY_API_TOKEN=your_auth_token

# Company Name in Tally
TALLY_COMPANY_NAME=YourCompanyName

# Port where Tally is running
TALLY_API_PORT=9000

# Other relevant configurations
TALLY_ACCOUNT_EMPLOYEE=your_employee_account
TALLY_ACCOUNT_VENDOR=your_vendor_account
